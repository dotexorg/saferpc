{
  "name": "@dotex/erpc",
  "version": "0.3.0",
  "description": "Encrypted RPC for any two counterparties over any bidirectional channel",
  "type": "module",
  "files": [
    "esm",
    "cjs",
    "src"
  ],
  "scripts": {
    "clean": "rm -rf esm cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('cjs/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "lint": "prettier --check 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "format": "prettier --write 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e/in-memory.test.ts test/e2e/message-port.test.ts test/e2e/websocket.test.ts",
    "test:security": "vitest run test/security",
    "test:browser": "vitest run test/e2e/browser.test.ts",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "prepublishOnly": "npm run build"
  },
  "author": "Dotex (https://dotex.org/about)",
  "homepage": "https://github.com/dotexorg/erpc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotexorg/erpc.git"
  },
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.3",
    "typescript": "6.x.x",
    "vitest": "^4.1.5",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./cjs/index.js",
  "types": "./esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.js"
    },
    "./common": {
      "types": "./esm/common.d.ts",
      "import": "./esm/common.js",
      "require": "./cjs/common.js"
    },
    "./client": {
      "types": "./esm/client.d.ts",
      "import": "./esm/client.js",
      "require": "./cjs/client.js"
    },
    "./server": {
      "types": "./esm/server.d.ts",
      "import": "./esm/server.js",
      "require": "./cjs/server.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "erpc",
    "rpc",
    "encrypted",
    "messaging",
    "x25519",
    "msgpack",
    "typescript"
  ]
}
